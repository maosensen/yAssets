{
	"name": "yassets",
	"private": true,
	"version": "0.1.4",
	"type": "module",
	"packageManager": "pnpm@10.33.4",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"format": "biome check --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
		"rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
		"rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
		"rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
		"check:bindings": "cargo test --manifest-path src-tauri/Cargo.toml export_bindings && git diff --exit-code src/lib/bindings.ts",
		"check": "pnpm typecheck && pnpm lint && pnpm test && pnpm check:bindings && pnpm rust:fmt:check && pnpm rust:clippy"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@fontsource-variable/outfit": "^5.2.8",
		"@hookform/resolvers": "^5.4.0",
		"@shadcn/react": "^0.1.0",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/react-query": "^5.101.2",
		"@tanstack/react-router": "^1.170.16",
		"@tanstack/react-virtual": "^3.14.4",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-dialog": "~2.7.1",
		"@tauri-apps/plugin-fs": "~2.5.1",
		"@tauri-apps/plugin-log": "~2.8.0",
		"@tauri-apps/plugin-opener": "^2",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-store": "~2.4.3",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"@tauri-apps/plugin-window-state": "~2.4.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.22.0",
		"motion": "^12.42.0",
		"nanoid": "^5.1.16",
		"next-themes": "^0.4.6",
		"pino": "^10.3.1",
		"react": "^19.1.0",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.1.0",
		"react-hook-form": "^7.80.0",
		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.12.0",
		"recharts": "3.8.0",
		"remark-gfm": "^4.0.1",
		"shadcn": "^4.12.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@iconify-json/solar": "^1.2.5",
		"@svgr/core": "^8.1.0",
		"@svgr/plugin-jsx": "^8.1.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tanstack/router-plugin": "^1.168.18",
		"@tauri-apps/cli": "^2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^26.0.1",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^4.6.0",
		"jsdom": "^29.1.1",
		"lefthook": "^2.1.9",
		"typescript": "~5.8.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.0.4",
		"vitest": "^4.1.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lefthook"
		]
	}
}
