{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "yAssets",
	"version": "0.1.9",
	"identifier": "com.maosensen.yassets",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "yAssets",
				"width": 1100,
				"height": 720,
				"minWidth": 720,
				"minHeight": 480,
				"resizable": true,
				"visible": false,
				"transparent": true,
				"theme": "Dark",
				"titleBarStyle": "Overlay",
				"hiddenTitle": true,
				"windowEffects": {
					"effects": ["sidebar", "mica", "acrylic", "blur"],
					"state": "followsWindowActiveState"
				}
			}
		],
		"security": {
			"csp": "default-src 'self'; img-src 'self' yasset: http://yasset.localhost data: blob: https://th.wallhaven.cc https://pixabay.com https://cdn.pixabay.com; media-src 'self' yasset: http://yasset.localhost; frame-src 'self' yasset: http://yasset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1421 http://localhost:1420 yasset: http://yasset.localhost"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCRTJBQUQ1N0Y3MUFENDgKUldSSXJYRi8xYXJpT3cxaG1DbkpDSW1SemNKRHQrOFdrNHo3eS9PVjNyTlgraTE2TXMzRE9lN20K",
			"endpoints": [
				"https://github.com/maosensen/yAssets/releases/latest/download/latest.json"
			]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"category": "Productivity",
		"copyright": "© 2026 maosensen",
		"shortDescription": "Cross-platform media/asset manager.",
		"longDescription": "yAssets is a cross-platform desktop media/asset manager built with Tauri 2.",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
